# =============================
# Lumura / MEMO DEV SaaS - Vercel Environment Variables
# انسخ القيم داخل Vercel > Project Settings > Environment Variables
# لا ترفع ملف .env الحقيقي إلى GitHub
# =============================

# App URL
NEXT_PUBLIC_APP_URL=https://YOUR-VERCEL-PROJECT.vercel.app
NEXTAUTH_URL=https://YOUR-VERCEL-PROJECT.vercel.app

# Auth / JWT
# استخدم قيمة عشوائية قوية 32 حرف أو أكثر لنفس المتغيرين
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
AUTH_SECRET=CHANGE_ME_SAME_AS_NEXTAUTH_SECRET
JWT_SECRET=CHANGE_ME_SAME_AS_NEXTAUTH_SECRET

# Database - MongoDB Atlas فقط على Vercel
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/lumura_saas?retryWrites=true&w=majority

# Super Admin seed / bootstrap
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe@123456789

# Cloudinary uploads
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Stripe payments - اتركها فارغة إذا لم تفعل الدفع الآن
STRIPE_SECRET_KEY=sk_live_OR_sk_test_REPLACE_ME
# STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Email SMTP - اترك EMAIL_DEV_MODE=true للتجربة بدون إرسال فعلي
EMAIL_DEV_MODE=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM="MEMO DEV <no-reply@example.com>"

# Optional rate limit / cache
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Production
NODE_ENV=production
